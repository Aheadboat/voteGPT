{
  "name": "votegpt",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "npm@11.11.0",
  "overrides": {
    "esbuild": "0.28.1",
    "postcss": "8.5.10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "db:check": "drizzle-kit check --dialect=postgresql --out=drizzle",
    "db:migrate": "drizzle-kit migrate",
    "db:rotate-residence-keys": "node scripts/rotate-saved-residence-keys.mts",
    "start": "next start",
    "test": "vitest run",
    "test:postgres": "vitest run --config vitest.postgres.config.mts",
    "typecheck": "next typegen && tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "check": "npm test && npm run typecheck && npm run lint && npm run build",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.6.23",
    "better-auth": "1.6.23",
    "drizzle-orm": "0.45.2",
    "next": "16.2.10",
    "nodemailer": "9.0.3",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.5.4",
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.13.3",
    "@types/nodemailer": "8.0.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
